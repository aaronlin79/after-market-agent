APP_NAME=After Market Agent
ENVIRONMENT=development
DATABASE_URL=sqlite:///./after_market_agent.db
DEBUG=true
DEFAULT_WATCHLIST_NAME=Default Watchlist
NEWS_PROVIDER=mock
NEWS_API_KEY=
SEC_USER_AGENT=after-market-agent dev@example.com
SEC_API_KEY=
INGESTION_LOOKBACK_HOURS=24
EMAIL_PROVIDER=brevo
# Brevo uses BREVO_API_KEY. EMAIL_API_KEY is still accepted as a legacy fallback.
BREVO_API_KEY=
# Resend uses RESEND_API_KEY. EMAIL_API_KEY is still accepted as a legacy fallback.
RESEND_API_KEY=
EMAIL_API_KEY=
EMAIL_FROM=digest@example.com
EMAIL_FROM_NAME=After Market Agent
DIGEST_RECIPIENTS=alice@example.com,bob@example.com
DIGEST_TIMEZONE=America/Los_Angeles
DIGEST_SEND_HOUR=6
ENABLE_SCHEDULER=false
SCHEDULED_WATCHLIST_ID=1
OPENAI_API_KEY=
OPENAI_MODEL_SUMMARY=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2
OPENAI_MAX_CLUSTERS_PER_RUN=25
OPENAI_MAX_CALLS_PER_RUN=25
